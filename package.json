{
  "name": "tad-marketplace",
  "private": true,
  "version": "0.0.0",
  "description": "Transactional site at marketplace.tad.com.mx — sells TAD product subscriptions. See CLAUDE.md.",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,mjs,js,json,md,yml,yaml}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,mjs,js,json,md,yml,yaml}\" --ignore-path .gitignore",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "build:lambdas": "node scripts/build-lambdas.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "eslint": "^9.7.0",
    "globals": "^15.8.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0"
  }
}
