# tad-marketplace local dev environment.
# Copy this file to `.env.local` (gitignored) and fill in real values.
# The backend dev-server (backend/scripts/dev-server.ts) loads it via dotenv.

# ─────────── AWS ───────────
# Credentials come from your CLI profile (AWS_PROFILE) or the env-var pair.
AWS_REGION=us-east-1
# AWS_PROFILE=tad

# ─────────── Auth (REQUIRED for /auth/verify) ───────────
# Any cryptographically random 32+ char string. Rotate every 90 days in prod.
# Generate one with:
#   node -e "console.log(require('node:crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=replace-me-with-a-32-char-or-longer-secret

# ─────────── SES ───────────
SES_FROM_ADDRESS=noreply@tad.com.mx
# When true, magic links are logged to the dev-server stdout instead of being
# sent via SES. Use this while SES is in sandbox or the recipient isn't verified.
MAGIC_LINK_DEV_MODE=true

# ─────────── Cookies ───────────
# Drop the `Secure` flag so Chrome accepts the session cookie over plain HTTP
# localhost. NEVER set this in production.
SESSION_COOKIE_INSECURE=true
# Set in production when FE and API live on different subdomains, e.g. `.tad.com.mx`.
# SESSION_COOKIE_DOMAIN=.tad.com.mx

# ─────────── URLs ───────────
# Backend uses this to build magic-link URLs and to gate CORS.
FRONTEND_URL=http://localhost:3000
# Frontend fetch wrapper uses this; must be reachable from the browser.
NEXT_PUBLIC_API_URL=http://localhost:8080

# ─────────── DynamoDB tables (defaults match CONTROL_PLANE.md) ───────────
# Override only if Terraform deploys tables under different names.
# DDB_TABLE_TENANTS=tad-mcp-aws-tenants
# DDB_TABLE_LICENSES=tad-mcp-aws-licenses
# DDB_TABLE_SEATS=tad-mcp-aws-seats
# DDB_TABLE_USAGE=tad-mcp-aws-usage-events
# DDB_TABLE_PRODUCTS=tad-mcp-aws-products
# DDB_TABLE_USERS=tad-marketplace-users
# DDB_TABLE_AUTH_TOKENS=tad-marketplace-auth-tokens

# ─────────── Installer bucket (S3) ───────────
# Private S3 bucket for product installers. Created by
# `scripts/setup-installer-bucket.ps1`. Object key convention:
#   s3://<bucket>/{product_id}/latest/installer
# Upload your installer manually with:
#   aws s3 cp ./TAD-MCP-Revit-Setup.msi s3://tad-installers/prd_revit_mcp/latest/installer
INSTALLER_BUCKET=tad-installers

# ─────────── PayPal ───────────
# Get sandbox keys at https://developer.paypal.com → Apps & Credentials → Sandbox.
# Sandbox accounts already include a "Default Application" — just copy its
# Client ID and Secret here. No need to create a new app unless you want a
# specific name.
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# Set after `/webhooks/paypal` is deployed AND registered in PayPal Dashboard
# → Webhooks. Required for webhook signature verification in webhook-paypal.ts.
PAYPAL_WEBHOOK_ID=

# ─────────── Dev server port ───────────
# PORT=8080
